PORT=5000
NODE_ENV=development
SERVE_FRONTEND=false
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/chatapp?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Frontend URL — required when SERVE_FRONTEND=false (separate Render deploy)
CLIENT_URL=https://mern-chat-frontend.onrender.com

# Local dev with separate frontend/backend:
# CLIENT_URL=http://localhost:3000
